{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "outDir": "./out",
    "rootDir": "./",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  },
  "include": ["main.js", "routes/**/*", "private/**/*", "keys/**/*", "assets/js/**/*"],
  "exclude": ["node_modules", "gui", "dist", "out"],
}
