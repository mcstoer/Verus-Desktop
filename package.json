{
  "name": "verus-desktop-testnet",
  "productName": "Verus-Desktop-Testnet",
  "version": "1.2.17-1",
  "description": "Verus Desktop Wallet App",
  "main": "out/main.js",
  "scripts": {
    "build": "tsc && copyfiles -f version.json out/ && copyfiles -u 0 'assets/**/*' out/",
    "start": "pnpm run build && cross-env NODE_ENV=development electron .",
    "start:all": "./scripts/prod.sh",
    "debug": "pnpm start devmode --no-sandbox",
    "dev:all": "./scripts/dev.sh",
    "make-patch": "./make-patch.sh",
    "install:all": "./scripts/setup.sh",
    "pack": "pnpm run build && cross-env NODE_ENV=production electron-builder --dir verus-unpacked",
    "dist": "pnpm run build && cross-env NODE_ENV=production electron-builder --publish=never  ",
    "dist-win": "pnpm run build && cross-env NODE_ENV=production electron-builder --publish=never  --win",
    "dist:all": "./scripts/create-build.sh",
    "dist-win:all": "./scripts/create-build-win.sh",
    "test": "mocha",
    "update-agamalib": "rm -rf node_modules/agama-wallet-lib/ && pnpm install",
    "postinstall": "rm -rf node_modules/bitgo-utxo-lib/node_modules/create-hash"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": "https://github.com/VerusCoin/Verus-Desktop/",
  "homepage": "https://verus.io",
  "keywords": [
    "agama",
    "SuperNET",
    "komodo",
    "multicoin",
    "wallet",
    "spv",
    "jumblr",
    "verus"
  ],
  "author": {
    "name": "Verus",
    "email": "development@veruscoin.io",
    "url": "https://verus.io"
  },
  "license": "MIT",
  "dependencies": {
    "@bitgo/utxo-lib": "git+https://github.com/VerusCoin/BitGoJS.git#2b0f428afbdbc0aa9541aa60b310c8f4c41fd2c5",
    "@electron/remote": "1.1.0",
    "@noble/curves": "1.2.0",
    "@xmldom/xmldom": "0.9.10",
    "agama-wallet-lib": "git+https://github.com/VerusCoin/agama-wallet-lib.git#dev",
    "ajv": "6.15.0",
    "arch": "2.1.0",
    "async": "2.6.4",
    "axios": "1.16.0",
    "base64url": "git+https://github.com/VerusCoin/base64url.git",
    "bigi": "1.4.2",
    "bitgo-utxo-lib": "git+https://github.com/VerusCoin/bitgo-utxo-lib.git",
    "blake2b": "git+https://github.com/VerusCoin/blake2b.git#777f844b986173d08fc27fe9547c6f6320a82d62",
    "body-parser": "1.19.1",
    "bs58check": "2.1.2",
    "buffer-reverse": "1.0.1",
    "coinselect": "github:bitcoinjs/coinselect#288f24d221e5f1e5beac883043cc706914b2b2bd",
    "create-hash": "git+https://github.com/pbca26/createHash#electron-v4",
    "crypto-js": "4.2.0",
    "csv-writer": "1.6.0",
    "ethers": "git+https://github.com/VerusCoin/ethers.js.git",
    "express": "4.19.2",
    "fix-path": "2.1.0",
    "fs-extra": "9.1.0",
    "graceful-fs": "4.1.11",
    "ini": "1.3.8",
    "iocane": "1.0.0",
    "node-cache": "5.1.2",
    "nodejs-aes256": "1.0.1",
    "passwd-strength": "https://github.com/michaeltout/passwd-strength.git",
    "portscanner": "2.2.0",
    "remote-file-size": "3.0.5",
    "request": "2.88.2",
    "semver-compare": "1.0.0",
    "sha256": "0.2.0",
    "socket.io": "4.6.2",
    "systeminformation": "5.31.6",
    "tx-builder": "0.18.0",
    "unzipper": "0.10.11",
    "verus-typescript-primitives": "git+https://github.com/VerusCoin/verus-typescript-primitives.git",
    "verus-wallet-endpoints": "git+https://github.com/VerusCoin/verus-wallet-endpoints.git",
    "verus_bridgekeeper": "git+https://github.com/VerusCoin/verusbridgekeeper.git#860dbe862780947bafb0b0c23b6f75c923bc9484",
    "verusd-rpc-ts-client": "git+https://github.com/VerusCoin/verusd-rpc-ts-client.git",
    "wif": "2.0.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "@types/node": "18.19.0",
    "copyfiles": "2.4.1",
    "cross-env": "5.2.1",
    "electron": "22.3.25",
    "electron-builder": "24.13.3",
    "electron-devtools-installer": "3.2.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.0.0",
    "prettier": "3.6.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.53.0"
  },
  "optionalDependencies": {
    "osx-temperature-sensor": "1.0.8"
  },
  "build": {
    "appId": "Verus",
    "files": [
      "package.json",
      "version.json",
      "out/**/*",
      "gui/**/*",
      "keys/**/*",
      "!**/*.ts",
      "!buildscripts",
      "!dist",
      "!test${/*}",
      "!windeps${/*}",
      "!.git*",
      "!Brewfile",
      "!README.md",
      "!make*",
      "!check_submodule.sh",
      "!gui/EasyDEX/react/node_modules${/*}",
      "!gui/EasyDEX/react/src${/*}",
      "!gui/EasyDEX/react/www${/*}"
    ],
    "includePdb": false,
    "asar": false,
    "mac": {
      "artifactName": "${productName}-v${version}.${ext}",
      "icon": "assets/icons/agama_icons/vrsc.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "icon": "assets/icons/vrsc.icns",
      "contents": [
        {
          "x": 135,
          "y": 220
        },
        {
          "x": 405,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "artifactName": "${productName}-v${version}-${arch}.${ext}",
      "icon": "assets/icons/agama_icons",
      "desktop": {
        "Encoding": "UTF-8",
        "MimeType": "x-scheme-handler/i5jtwbp6zymeay9llnraglgjqgdrffsau4;x-scheme-handler/verus"
      },
      "target": [
        "appimage"
      ]
    },
    "win": {
      "artifactName": "${productName}-v${version}.${ext}",
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/vrsc.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE",
      "installerIcon": "assets/icons/vrsc.ico"
    }
  }
}
